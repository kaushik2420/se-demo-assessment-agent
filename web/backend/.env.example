# ----- Required -----

# Postgres connection string. Render injects this automatically when you link
# the database; for local dev, sqlite is the default fallback.
DATABASE_URL=postgresql://user:pwd@host:5432/se_coach

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-48-bytes-of-randomness

# Comma-separated list of allowed origins (your Vercel URL goes here)
CORS_ORIGINS=http://localhost:3000,https://se-coach.vercel.app

# ----- Optional -----

# Granola Business plan API key (when ready — bypasses paste-flow)
GRANOLA_API_KEY=

# AWS SES (for monthly digest emails — defer to phase 2)
SES_FROM_EMAIL=
SES_CC_EMAIL=kaushikn2416@gmail.com
